# Obsidian — fresh vault, opened in Obsidian as a separate vault
OBSIDIAN_VAULT_PATH=/Users/shreyaraj/Obsidian/Frame

# Langfuse (cloud free tier — https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
