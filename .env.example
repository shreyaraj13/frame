# Tavily (web search, used by Explorer)
TAVILY_API_KEY=tvly-...

# Runtime
FRAME_LOG_LEVEL=INFO
FRAME_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
